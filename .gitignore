# Pipeline output — never commit these.
# The scoring system provides the output directory via volume mount;
# any output baked into your image is unreachable.
output/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Virtual environments
.venv/
venv/
env/

# macOS
.DS_Store

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# Jupyter
.ipynb_checkpoints/

# Stream data (Stage 3) — provided via Docker mount during scoring
stream/*.jsonl

# Test artefacts
.pytest_cache/
